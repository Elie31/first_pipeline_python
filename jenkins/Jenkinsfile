pipeline {
    agent any
    stages {
        stage('Build') { 
            steps {
                withPythonEnv('python3') {
                    sh 'pip3 install -r sources/requirements.txt'
                }
            }
        }
        stage('Test') { 
            steps {
                withPythonEnv('python3') {
                    sh 'python3 sources/test_calc.py'
                }
            }
        }
        stage('Vuln Scan Hight') { 
            steps {
                withPythonEnv('python3') {
                    sh '''
                    pip install bandit
                    bandit -r ./sources/ -lll -f json -o bandit-report.json
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'bandit-report.json'
                }
            }   
        }
        stage('Secret Detect Scan') { 
            steps {
                withPythonEnv('python3') {
                    sh '''
                    set -e
                    pip install detect-secrets
                    detect-secrets scan > ./jenkins/.secrets.baseline
                    python3 ./jenkins/detect_secrets.py
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: './jenkins/.secrets.baseline'
                }
            }
        }
    }
}